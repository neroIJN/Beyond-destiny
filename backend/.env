# Server
PORT=8080
FRONTEND_URL=http://localhost:5173

# PostgreSQL
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://postgres:root@localhost:5432/captured_moments

# JWT - generate a strong random secret, e.g.: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# Backblaze B2 Storage
# Get these from your Backblaze B2 account -> App Keys
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_KEY_ID=005bd546a9a17310000000001
B2_APPLICATION_KEY=K005/rnaBJdSlqnxQFSl5g6XHG1j7cs
B2_BUCKET_NAME=captured-moments-photos
# Public URL base — pattern: https://f{region}.backblazeb2.com/file/{bucket-name}
# Your region is 005 (from endpoint us-east-005), so prefix is f005
B2_PUBLIC_BASE_URL=https://f005.backblazeb2.com/file/captured-moments-photos

# Email Notifications (optional - form submissions still save to DB without this)
# For Gmail: use App Password (not your real password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
# Where to send new inquiry notifications
NOTIFY_EMAIL=owner@yourstudio.com
