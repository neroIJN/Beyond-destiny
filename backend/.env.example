# Server
PORT=8080
FRONTEND_URL=http://localhost:5173

# PostgreSQL
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/captured_moments

# JWT - generate a strong random secret, e.g.: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# Backblaze B2 Storage
# Get these from your Backblaze B2 account -> App Keys
# Endpoint format: https://s3.us-west-004.backblazeb2.com  (check your bucket region)
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_KEY_ID=your-b2-key-id
B2_APPLICATION_KEY=your-b2-application-key
B2_BUCKET_NAME=your-bucket-name
# Public URL base - if using Cloudflare CDN: https://cdn.yourdomain.com
# Otherwise Backblaze direct: https://f004.backblazeb2.com/file/your-bucket-name
B2_PUBLIC_BASE_URL=https://f004.backblazeb2.com/file/your-bucket-name

# Email Notifications (optional - form submissions still save to DB without this)
# For Gmail: use App Password (not your real password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
# Where to send new inquiry notifications
NOTIFY_EMAIL=owner@yourstudio.com
